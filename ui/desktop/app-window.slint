import {
    Button,
    ComboBox,
    HorizontalBox,
    Slider,
    StandardListView,
    TextEdit,
    VerticalBox,
} from "std-widgets.slint";

component MetaItem inherits Rectangle {
    in property <string> label;
    in property <string> value;

    background: transparent;
    min-height: 34px;

    VerticalBox {
        alignment: start;
        spacing: 2px;

        Text {
            text: root.label;
            font-size: 11px;
            color: #9aa6b2;
        }

        Text {
            text: root.value;
            font-size: 13px;
            color: #f4f7fb;
            wrap: word-wrap;
        }
    }
}

component OverlayPanel inherits Rectangle {
    background: #171a20;
    border-width: 1px;
    border-color: #343b47;
    border-radius: 6px;
}

component PanelTitle inherits Text {
    font-size: 14px;
    font-weight: 600;
    color: #f4f7fb;
}

component MutedText inherits Text {
    font-size: 12px;
    color: #9aa6b2;
    wrap: word-wrap;
}

component Divider inherits Rectangle {
    height: 1px;
    background: #2b323d;
}

component ActionButton inherits Rectangle {
    in property <string> text;
    in property <bool> primary: false;
    in property <bool> enabled: true;
    callback clicked();

    height: 36px;
    background: !root.enabled ? #20242c : root.primary ? #5fc7ee : touch.pressed ? #303642 : touch.has-hover ? #343b47 : #242832;
    border-width: 1px;
    border-color: !root.enabled ? #2b3039 : root.primary ? #5fc7ee : #343b47;
    border-radius: 5px;

    Text {
        x: 8px;
        y: 0;
        width: parent.width - 16px;
        height: parent.height;
        text: root.text;
        font-size: 13px;
        color: !root.enabled ? #7d8793 : root.primary ? #071017 : #f4f7fb;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

export component AppWindow inherits Window {
    in property <string> workspace_name;
    in property <string> workspace_path_text;
    in property <string> session_summary_text;
    in property <string> selection_title;
    in property <string> current_session_title;
    in property <string> provider_title;
    in property <string> model_title;
    in property <string> access_mode_title;
    in property <string> run_status_text;
    in property <string> progress_text;
    in property <string> transcript_text;
    in property <string> tool_status_text;
    in property <string> status_banner_text;
    in property <string> confirmation_text;
    in property <[StandardListViewItem]> session_items;
    in-out property <int> current_session_index: -1;
    in-out property <string> composer_text;
    in-out property <string> image_path_text;
    in property <string> image_summary_text;
    in property <bool> image_attach_enabled: false;
    in property <bool> image_clear_enabled: false;
    in property <bool> run_enabled: false;
    in property <bool> review_enabled: false;
    in property <bool> open_session_enabled: false;
    in property <bool> history_export_enabled: false;
    in property <bool> enhance_enabled: false;
    in property <bool> confirmation_visible: false;
    in property <bool> config_visible: false;
    in property <[StandardListViewItem]> config_items;
    in-out property <int> current_config_index: 0;
    in property <string> config_field_title;
    in-out property <string> config_value_text;
    in property <string> config_feedback_text;
    in property <bool> provider_visible: false;
    in-out property <string> provider_base_url_text;
    in property <[string]> provider_model_items;
    in-out property <int> current_provider_model_index: -1;
    in property <string> provider_feedback_text;
    in property <string> provider_load_button_text: "Load Models";
    in property <bool> provider_load_enabled: true;
    in property <bool> provider_apply_enabled: false;
    in property <bool> workspace_picker_visible: false;
    in-out property <string> workspace_input_text;
    in property <bool> review_visible: false;
    in property <string> review_raw_text;
    in-out property <string> review_draft_text;
    in property <string> review_status_text;
    in property <bool> send_enhanced_enabled: false;
    in property <bool> send_raw_enabled: false;
    in property <float> window_opacity_percent: 96;
    in property <string> window_opacity_text: "96%";

    callback session_selected(int);
    callback composer_changed(string);
    callback image_path_changed(string);
    callback image_attach_requested();
    callback image_browse_requested();
    callback image_clear_requested();
    callback refresh_requested();
    callback session_reload_requested();
    callback history_export_requested();
    callback run_requested();
    callback review_requested();
    callback enhance_requested();
    callback open_folder_requested();
    callback config_editor_requested();
    callback provider_editor_requested();
    callback access_mode_toggle_requested();
    callback config_close_requested();
    callback config_selected(int);
    callback config_value_changed(string);
    callback config_apply_session_requested();
    callback config_save_project_requested();
    callback config_save_global_requested();
    callback provider_close_requested();
    callback provider_base_url_changed(string);
    callback provider_load_requested();
    callback provider_model_selected(string);
    callback provider_apply_session_requested();
    callback provider_save_project_requested();
    callback provider_save_global_requested();
    callback workspace_picker_requested();
    callback workspace_close_requested();
    callback workspace_input_changed(string);
    callback workspace_apply_requested();
    callback workspace_browse_requested();
    callback open_typed_path_requested();
    callback review_draft_changed(string);
    callback send_enhanced_requested();
    callback send_raw_requested();
    callback cancel_review_requested();
    callback confirm_accept_requested();
    callback confirm_reject_requested();
    callback window_opacity_changed(float);

    title: "moyAI Desktop";
    icon: @image-url("../../logo/fabicon/android-chrome-512x512.png");
    preferred-width: 1360px;
    preferred-height: 900px;
    min-width: 1040px;
    min-height: 720px;
    background: transparent;

    Rectangle {
        background: transparent;

        panel := Rectangle {
            x: 0;
            y: 0;
            width: parent.width;
            height: parent.height;
            background: #101216;
            border-width: 1px;
            border-color: #2a303a;
            opacity: root.window_opacity_percent / 100;

            VerticalBox {
                padding: 12px;
                spacing: 10px;

                Rectangle {
                    height: 112px;
                    background: #171a20;
                    border-width: 1px;
                    border-color: #2d3440;
                    border-radius: 6px;

                    VerticalBox {
                        padding: 12px;
                        spacing: 8px;

                        HorizontalBox {
                            height: 42px;
                            spacing: 12px;

                            Rectangle {
                                horizontal-stretch: 1;
                                background: transparent;

                                VerticalBox {
                                    alignment: start;
                                    spacing: 3px;

                                    Text {
                                        text: "moyAI Desktop";
                                        font-size: 22px;
                                        font-weight: 700;
                                        color: #f3f4ef;
                                    }

                                    Text {
                                        text: root.workspace_path_text;
                                        font-size: 12px;
                                        color: #9aa6b2;
                                        wrap: word-wrap;
                                    }
                                }
                            }

                            Rectangle {
                                width: 240px;
                                background: transparent;

                                VerticalBox {
                                    alignment: center;
                                    spacing: 4px;

                                    Text {
                                        text: "Opacity";
                                        font-size: 11px;
                                        color: #9aa6b2;
                                    }

                                    HorizontalBox {
                                        alignment: center;
                                        spacing: 8px;

                                        Slider {
                                            width: 120px;
                                            minimum: 55;
                                            maximum: 100;
                                            step: 1;
                                            value: root.window_opacity_percent;
                                            changed(value) => {
                                                root.window_opacity_changed(value);
                                            }
                                        }

                                        Text {
                                            text: root.window_opacity_text;
                                            min-width: 40px;
                                            font-size: 12px;
                                            color: #f4f7fb;
                                            horizontal-alignment: center;
                                        }
                                    }

                                    Text {
                                        text: root.current_session_title;
                                        font-size: 11px;
                                        color: #5ee6c1;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }

                        HorizontalBox {
                            height: 34px;
                            spacing: 8px;

                            Button {
                                text: "Workspace";
                                width: 108px;
                                height: 32px;
                                clicked => { root.workspace_picker_requested(); }
                            }

                            Button {
                                text: "Provider";
                                width: 104px;
                                height: 32px;
                                clicked => { root.provider_editor_requested(); }
                            }

                            Button {
                                text: "Config";
                                width: 92px;
                                height: 32px;
                                clicked => { root.config_editor_requested(); }
                            }

                            Button {
                                text: "Folder";
                                width: 92px;
                                height: 32px;
                                clicked => { root.open_folder_requested(); }
                            }

                            Button {
                                text: "Access: " + root.access_mode_title;
                                width: 146px;
                                height: 32px;
                                clicked => { root.access_mode_toggle_requested(); }
                            }

                            Button {
                                text: "Open";
                                width: 76px;
                                height: 32px;
                                enabled: root.open_session_enabled;
                                clicked => { root.session_reload_requested(); }
                            }

                            Button {
                                text: "Export";
                                width: 76px;
                                height: 32px;
                                enabled: root.history_export_enabled;
                                clicked => { root.history_export_requested(); }
                            }

                            Rectangle {
                                background: transparent;
                                horizontal-stretch: 1;
                            }

                            MutedText {
                                text: root.status_banner_text;
                            }
                        }
                    }
                }

                HorizontalBox {
                    spacing: 12px;
                    vertical-stretch: 1;

                    Rectangle {
                        min-width: 270px;
                        max-width: 300px;
                        background: #171a20;
                        border-width: 1px;
                        border-color: #2d3440;
                        border-radius: 6px;

                        VerticalBox {
                            padding: 12px;
                            spacing: 9px;

                            PanelTitle {
                                text: "Workspace";
                            }

                            Text {
                                text: root.workspace_name;
                                font-size: 18px;
                                font-weight: 600;
                                color: #f4f7fb;
                            }

                            MetaItem {
                                label: "Path";
                                value: root.workspace_path_text;
                            }

                            MetaItem {
                                label: "Provider";
                                value: root.provider_title;
                            }

                            MetaItem {
                                label: "Model";
                                value: root.model_title;
                            }

                            MetaItem {
                                label: "Access";
                                value: root.access_mode_title;
                            }

                            MetaItem {
                                label: "Run Target";
                                value: root.current_session_title;
                            }

                            Divider {}

                            HorizontalBox {
                                spacing: 8px;

                                PanelTitle {
                                    text: "Sessions";
                                }

                                Rectangle {
                                    background: transparent;
                                    horizontal-stretch: 1;
                                }

                                Text {
                                    text: root.session_summary_text;
                                    font-size: 11px;
                                    color: #9aa6b2;
                                }
                            }

                            StandardListView {
                                vertical-stretch: 1;
                                model: root.session_items;
                                current-item: root.current_session_index;
                                current-item-changed(index) => {
                                    root.session_selected(index);
                                }
                            }
                        }
                    }

                    Rectangle {
                        background: #171a20;
                        border-width: 1px;
                        border-color: #2d3440;
                        border-radius: 6px;
                        horizontal-stretch: 3;

                        VerticalBox {
                            padding: 12px;
                            spacing: 9px;

                            PanelTitle {
                                text: "Transcript";
                            }

                            MutedText {
                                text: root.selection_title;
                            }

                            TextEdit {
                                vertical-stretch: 1;
                                read-only: true;
                                text: root.transcript_text;
                                font-size: 13px;
                            }
                        }
                    }

                    Rectangle {
                        min-width: 280px;
                        max-width: 320px;
                        background: #171a20;
                        border-width: 1px;
                        border-color: #2d3440;
                        border-radius: 6px;

                        VerticalBox {
                            padding: 12px;
                            spacing: 9px;

                            PanelTitle {
                                text: "Progress";
                            }

                            MutedText {
                                text: root.selection_title;
                            }

                            TextEdit {
                                height: 136px;
                                read-only: true;
                                text: root.progress_text;
                                font-size: 13px;
                            }

                            PanelTitle {
                                text: "Activity";
                            }

                            TextEdit {
                                vertical-stretch: 1;
                                read-only: true;
                                text: root.tool_status_text;
                                font-size: 13px;
                            }
                        }
                    }
                }

                Rectangle {
                    height: 220px;
                    background: #171a20;
                    border-width: 1px;
                    border-color: #2d3440;
                    border-radius: 6px;

                    HorizontalBox {
                        padding: 12px;
                        spacing: 12px;

                        VerticalBox {
                            spacing: 8px;
                            horizontal-stretch: 1;

                            HorizontalBox {
                                spacing: 8px;

                                PanelTitle {
                                    text: "Prompt";
                                }

                                Rectangle {
                                    background: transparent;
                                    horizontal-stretch: 1;
                                }

                                Text {
                                    text: root.current_session_title;
                                    font-size: 11px;
                                    color: #5ee6c1;
                                }
                            }

                            MutedText {
                                text: root.status_banner_text;
                            }

                            TextEdit {
                                vertical-stretch: 1;
                                text: root.composer_text;
                                edited(text) => {
                                    root.composer_changed(text);
                                }
                            }

                            HorizontalBox {
                                spacing: 8px;

                                TextEdit {
                                    horizontal-stretch: 1;
                                    height: 34px;
                                    text: root.image_path_text;
                                    edited(text) => {
                                        root.image_path_changed(text);
                                    }
                                }

                                Button {
                                    text: "Attach";
                                    width: 92px;
                                    enabled: root.image_attach_enabled;
                                    clicked => { root.image_attach_requested(); }
                                }

                                Button {
                                    text: "Browse";
                                    width: 92px;
                                    clicked => { root.image_browse_requested(); }
                                }

                                Button {
                                    text: "Clear";
                                    width: 82px;
                                    enabled: root.image_clear_enabled;
                                    clicked => { root.image_clear_requested(); }
                                }
                            }

                            MutedText {
                                text: root.image_summary_text;
                            }
                        }

                        VerticalBox {
                            spacing: 8px;
                            width: 176px;

                            Button {
                                text: "Send";
                                height: 42px;
                                primary: true;
                                enabled: root.run_enabled;
                                clicked => { root.run_requested(); }
                            }

                            Button {
                                text: "Enhance";
                                height: 34px;
                                enabled: root.enhance_enabled;
                                clicked => { root.enhance_requested(); }
                            }

                            Button {
                                text: "Review";
                                height: 34px;
                                enabled: root.review_enabled;
                                clicked => { root.review_requested(); }
                            }

                            Button {
                                text: "Refresh";
                                height: 32px;
                                clicked => { root.refresh_requested(); }
                            }
                        }
                    }
                }

            }

            if root.config_visible : OverlayPanel {
                x: 132px;
                y: 96px;
                width: parent.width - 264px;
                height: 560px;

                VerticalBox {
                    padding: 14px;
                    spacing: 12px;

                    HorizontalBox {
                        spacing: 8px;

                        Text {
                            text: "Config Editor";
                            font-size: 16px;
                            color: #f3f4ef;
                        }

                        Rectangle {
                            background: transparent;
                            horizontal-stretch: 1;
                        }
                    }

                    HorizontalBox {
                        spacing: 12px;
                        vertical-stretch: 1;

                        Rectangle {
                            background: #1c2028;
                            border-width: 1px;
                            border-color: #343b47;
                            border-radius: 6px;
                            min-width: 420px;

                            VerticalBox {
                                padding: 10px;
                                spacing: 8px;

                                Text {
                                    text: "Fields";
                                    font-size: 14px;
                                    color: #f3f4ef;
                                }

                                VerticalBox {
                                    vertical-stretch: 1;
                                    spacing: 4px;

                                    for item[index] in root.config_items : Button {
                                        width: 384px;
                                        height: 34px;
                                        text: item.text;
                                        clicked => {
                                            root.current_config_index = index;
                                            root.config_selected(index);
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            background: #1c2028;
                            border-width: 1px;
                            border-color: #343b47;
                            border-radius: 6px;
                            horizontal-stretch: 1;

                            VerticalBox {
                                padding: 10px;
                                spacing: 8px;

                                Text {
                                    text: root.config_field_title;
                                    font-size: 14px;
                                    color: #f3f4ef;
                                }

                                Text {
                                    text: root.config_feedback_text;
                                    font-size: 12px;
                                    color: #9aa6b2;
                                    wrap: word-wrap;
                                }

                                TextEdit {
                                    vertical-stretch: 1;
                                    text: root.config_value_text;
                                    edited(text) => {
                                        root.config_value_changed(text);
                                    }
                                }
                            }
                        }
                    }

                    HorizontalBox {
                        spacing: 8px;

                        Rectangle {
                            background: transparent;
                            horizontal-stretch: 1;
                        }

                        Button {
                            text: "Cancel";
                            width: 112px;
                            height: 36px;
                            clicked => { root.config_close_requested(); }
                        }

                        Button {
                            text: "Apply Session";
                            width: 144px;
                            height: 36px;
                            primary: true;
                            clicked => { root.config_apply_session_requested(); }
                        }

                        Button {
                            text: "Save Project";
                            width: 144px;
                            height: 36px;
                            clicked => { root.config_save_project_requested(); }
                        }

                        Button {
                            text: "Save Global";
                            width: 144px;
                            height: 36px;
                            clicked => { root.config_save_global_requested(); }
                        }
                    }
                }
            }

            if root.workspace_picker_visible : OverlayPanel {
                x: 172px;
                y: 148px;
                width: parent.width - 344px;
                height: 306px;

                VerticalBox {
                    padding: 14px;
                    spacing: 12px;

                    HorizontalBox {
                        spacing: 8px;

                        Text {
                            text: "Workspace Picker";
                            font-size: 16px;
                            color: #f3f4ef;
                        }

                        Rectangle {
                            background: transparent;
                            horizontal-stretch: 1;
                        }
                    }

                    Text {
                        text: "Type a directory path, browse for a folder, then switch the active workspace.";
                        font-size: 12px;
                        color: #9aa6b2;
                        wrap: word-wrap;
                    }

                    TextEdit {
                        height: 42px;
                        text: root.workspace_input_text;
                        edited(text) => {
                            root.workspace_input_changed(text);
                        }
                    }

                    HorizontalBox {
                        spacing: 8px;

                        ActionButton {
                            text: "Browse Folder...";
                            width: 148px;
                            clicked => { root.workspace_browse_requested(); }
                        }

                        ActionButton {
                            text: "Open Typed Path";
                            width: 152px;
                            clicked => { root.open_typed_path_requested(); }
                        }

                        Rectangle {
                            background: transparent;
                            horizontal-stretch: 1;
                        }
                    }

                    Rectangle {
                        background: transparent;
                        vertical-stretch: 1;
                    }

                    HorizontalBox {
                        spacing: 8px;

                        Rectangle {
                            background: transparent;
                            horizontal-stretch: 1;
                        }

                        ActionButton {
                            text: "Cancel";
                            width: 112px;
                            clicked => { root.workspace_close_requested(); }
                        }

                        ActionButton {
                            text: "Switch Workspace";
                            width: 164px;
                            primary: true;
                            clicked => { root.workspace_apply_requested(); }
                        }
                    }
                }
            }

            if root.provider_visible : OverlayPanel {
                x: 140px;
                y: 96px;
                width: parent.width - 280px;
                height: 620px;

                VerticalBox {
                    padding: 14px;
                    spacing: 12px;

                    HorizontalBox {
                        spacing: 8px;

                        Text {
                            text: "Provider Settings";
                            font-size: 16px;
                            color: #f3f4ef;
                        }

                        Rectangle {
                            background: transparent;
                            horizontal-stretch: 1;
                        }
                    }

                    MutedText {
                        text: "Enter the provider URL, load the available models, then select one model to apply or save.";
                    }

                    VerticalBox {
                        spacing: 8px;

                        Text {
                            text: "Provider URL";
                            font-size: 13px;
                            color: #f3f4ef;
                        }

                        TextEdit {
                            height: 42px;
                            text: root.provider_base_url_text;
                            edited(text) => {
                                root.provider_base_url_changed(text);
                            }
                        }
                    }

                    HorizontalBox {
                        spacing: 8px;

                        Button {
                            text: root.provider_load_button_text;
                            width: 144px;
                            enabled: root.provider_load_enabled;
                            clicked => { root.provider_load_requested(); }
                        }

                        Rectangle {
                            background: transparent;
                            horizontal-stretch: 1;
                        }
                    }

                    VerticalBox {
                        spacing: 8px;

                        Text {
                            text: "Model";
                            font-size: 13px;
                            color: #f3f4ef;
                        }

                        ComboBox {
                            model: root.provider_model_items;
                            current-index: root.current_provider_model_index;
                            selected(value) => {
                                root.provider_model_selected(value);
                            }
                        }
                    }

                    TextEdit {
                        height: 86px;
                        read-only: true;
                        text: root.provider_feedback_text;
                        font-size: 12px;
                    }

                    Rectangle {
                        background: transparent;
                        vertical-stretch: 1;
                    }

                    HorizontalBox {
                        spacing: 8px;

                        Button {
                            text: "Save Project";
                            width: 144px;
                            height: 36px;
                            enabled: root.provider_apply_enabled;
                            clicked => { root.provider_save_project_requested(); }
                        }

                        Button {
                            text: "Save Global";
                            width: 144px;
                            height: 36px;
                            enabled: root.provider_apply_enabled;
                            clicked => { root.provider_save_global_requested(); }
                        }

                        Rectangle {
                            background: transparent;
                            horizontal-stretch: 1;
                        }

                        Button {
                            text: "Cancel";
                            width: 112px;
                            height: 36px;
                            clicked => { root.provider_close_requested(); }
                        }

                        Button {
                            text: "OK - Apply Session";
                            width: 184px;
                            height: 36px;
                            primary: true;
                            enabled: root.provider_apply_enabled;
                            clicked => { root.provider_apply_session_requested(); }
                        }
                    }
                }
            }

            if root.review_visible : OverlayPanel {
                x: 52px;
                y: 74px;
                width: parent.width - 104px;
                height: parent.height - 148px;

                VerticalBox {
                    padding: 14px;
                    spacing: 12px;

                    HorizontalBox {
                        spacing: 8px;

                        Text {
                            text: "Prompt Review";
                            font-size: 16px;
                            color: #f3f4ef;
                        }

                        Rectangle {
                            background: transparent;
                            horizontal-stretch: 1;
                        }
                    }

                    Text {
                        text: root.review_status_text;
                        font-size: 12px;
                        color: #9aa6b2;
                        wrap: word-wrap;
                    }

                    HorizontalBox {
                        spacing: 12px;
                        vertical-stretch: 1;

                        Rectangle {
                            background: #1c2028;
                            border-width: 1px;
                            border-color: #343b47;
                            border-radius: 6px;
                            horizontal-stretch: 1;

                            VerticalBox {
                                padding: 10px;
                                spacing: 8px;

                                Text {
                                    text: "Raw Prompt";
                                    font-size: 14px;
                                    color: #f3f4ef;
                                }

                                TextEdit {
                                    vertical-stretch: 1;
                                    read-only: true;
                                    text: root.review_raw_text;
                                }
                            }
                        }

                        Rectangle {
                            background: #1c2028;
                            border-width: 1px;
                            border-color: #343b47;
                            border-radius: 6px;
                            horizontal-stretch: 1;

                            VerticalBox {
                                padding: 10px;
                                spacing: 8px;

                                Text {
                                    text: "Enhanced Draft";
                                    font-size: 14px;
                                    color: #f3f4ef;
                                }

                                TextEdit {
                                    vertical-stretch: 1;
                                    text: root.review_draft_text;
                                    edited(text) => {
                                        root.review_draft_changed(text);
                                    }
                                }
                            }
                        }
                    }

                    HorizontalBox {
                        spacing: 8px;

                        Rectangle {
                            background: transparent;
                            horizontal-stretch: 1;
                        }

                        Button {
                            text: "Cancel";
                            width: 112px;
                            height: 36px;
                            clicked => { root.cancel_review_requested(); }
                        }

                        Button {
                            text: "Send Raw";
                            width: 124px;
                            height: 36px;
                            enabled: root.send_raw_enabled;
                            clicked => { root.send_raw_requested(); }
                        }

                        Button {
                            text: "Send Enhanced";
                            width: 148px;
                            height: 36px;
                            primary: true;
                            enabled: root.send_enhanced_enabled;
                            clicked => { root.send_enhanced_requested(); }
                        }
                    }
                }
            }

            if root.confirmation_visible : OverlayPanel {
                x: 248px;
                y: 214px;
                width: parent.width - 496px;
                height: 240px;

                VerticalBox {
                    padding: 14px;
                    spacing: 12px;

                    Text {
                        text: "Confirmation";
                        font-size: 16px;
                        color: #f3f4ef;
                    }

                    TextEdit {
                        vertical-stretch: 1;
                        read-only: true;
                        text: root.confirmation_text;
                        font-size: 13px;
                    }

                    HorizontalBox {
                        spacing: 8px;

                        Rectangle {
                            background: transparent;
                            horizontal-stretch: 1;
                        }

                        Button {
                            text: "Reject";
                            width: 128px;
                            height: 36px;
                            clicked => { root.confirm_reject_requested(); }
                        }

                        Button {
                            text: "Approve";
                            width: 128px;
                            height: 36px;
                            primary: true;
                            clicked => { root.confirm_accept_requested(); }
                        }
                    }
                }
            }
        }
    }
}
