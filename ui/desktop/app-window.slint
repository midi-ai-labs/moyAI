                        }
                    }

                    MutedText {
                        text: "Local .moyai/commands entries are inserted into the prompt as slash commands.";
                    }

                    StandardListView {
                        vertical-stretch: 1;
                        model: root.command_items;
                        current-item-changed(index) => { root.command_selected(index); }
                    }
                }
            }

            if root.keyboard_shortcuts_visible : OverlayPanel {
                x: 380px;
                y: 160px;
                width: parent.width - 760px;
                height: 320px;

                VerticalBox {
                    padding: 14px;
                    spacing: 12px;

                    HorizontalBox {
                        Text {
                            text: "Keyboard Shortcuts";
                            font-size: 16px;
                            color: #f3f4ef;
                        }

                        Rectangle { background: transparent; horizontal-stretch: 1; }

                        Button {
                            text: "Close";
                            width: 96px;
                            clicked => { root.overlay_close_requested(); }
                        }
                    }

                    TextEdit {
                        vertical-stretch: 1;
                        read-only: true;
                        text: root.keyboard_shortcuts_text;
                        font-size: 13px;
                    }
                }
            }

            if root.confirmation_visible : OverlayPanel {
                x: 248px;
                y: 214px;
                width: parent.width - 496px;
                height: 240px;

                VerticalBox {
                    padding: 14px;
                    spacing: 12px;

                    Text {
                        text: "Confirmation";
                        font-size: 16px;
                        color: #f3f4ef;
                    }

                    TextEdit {
                        vertical-stretch: 1;
                        read-only: true;
                        text: root.confirmation_text;
                        font-size: 13px;
                    }

                    HorizontalBox {
                        spacing: 8px;

                        Rectangle {
                            background: transparent;
                            horizontal-stretch: 1;
                        }

                        Button {
                            text: "Reject";
                            width: 128px;
                            height: 36px;
                            clicked => { root.confirm_reject_requested(); }
                        }

                        Button {
                            text: "Approve";
                            width: 128px;
                            height: 36px;
                            primary: true;
                            clicked => { root.confirm_accept_requested(); }
                        }
                    }
                }
            }
        }
    }
}
